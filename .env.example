# Copy this file to .env and fill in your own values
# .env is gitignored — never commit real secrets

# SQL Server SA password (must include upper, lower, number, symbol)
SA_PASSWORD=YourStrong!Passw0rd

# AES-256 server-side encryption key — must be EXACTLY 32 characters
ENCRYPTION_KEY=CHANGE_ME_32_CHAR_SECRET_KEY_HERE

# JWT signing key — must be AT LEAST 64 characters for HMAC-SHA512
JWT_SECRET=CHANGE_ME_VERY_LONG_JWT_SECRET_KEY_AT_LEAST_64_CHARS_LONG!!!!!!
