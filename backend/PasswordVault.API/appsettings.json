{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=PasswordVaultDB;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Security": {
    "EncryptionKey": "CHANGE_ME_32_CHAR_SECRET_KEY_HERE",
    "JwtSecret": "CHANGE_ME_VERY_LONG_JWT_SECRET_KEY_FOR_PRODUCTION_USE_AT_LEAST_64_CHARS",
    "JwtIssuer": "PasswordVaultAPI",
    "JwtAudience": "PasswordVaultClient",
    "JwtExpiryMinutes": 60
  },
  "AllowedOrigins": [
    "http://localhost:4200",
    "https://your-production-domain.com"
  ],
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
